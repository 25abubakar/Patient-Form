@model Patient_Form.Models.CheckupModel

@{
    ViewData["Title"] = "Online Check Up";
}

<h2>Online Check Up Booking</h2>

<div class="container">

    <form asp-action="OnlineCheckup" method="post">

        <div class="form-group mb-3">
            <label>Name</label>
            <input asp-for="Name" class="form-control" placeholder="Enter your name" />
        </div>

        <div class="form-group mb-3">
            <label>Email</label>
            <input asp-for="Email" class="form-control" placeholder="Enter your email" />
        </div>

        <div class="form-group mb-3">
            <label>Phone</label>
            <input asp-for="Phone" class="form-control" placeholder="Enter your phone" />
        </div>

        <div class="form-group mb-3">
            <label>City</label>
            <input asp-for="City" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Appointment Date</label>
            <input asp-for="AppointmentDate" type="date" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Message</label>
            <textarea asp-for="Message" class="form-control"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">
            Book Appointment
        </button>

    </form>
</div>

<hr />

<h4>Booked Appointments (Notifications)</h4>

@if (ViewBag.Appointments != null)
{
    <ul class="list-group">
        @foreach (var item in ViewBag.Appointments)
        {
            <li class="list-group-item">
                <b>@item.Name</b> booked for @item.AppointmentDate
            </li>
        }
    </ul>
}