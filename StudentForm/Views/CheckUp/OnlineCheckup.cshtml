@model Patient_Form.Models.CheckupModel
@{
    ViewData["Title"] = "Online Check Up";
}

<div class="container mt-4">
    <h2 class="text-center">🩺 Online Doctor Appointment</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["Error"]
        </div>
    }
</div>
<div class="card shadow-sm mb-5">
    <div class="card-body">
        <form asp-controller="Checkup" asp-action="OnlineCheckup" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6 mb-3">
                    <label>First Name</label>
                    <input asp-for="FName" class="form-control" required />
                    <span asp-validation-for="FName" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Last Name</label>
                    <input asp-for="LstName" class="form-control" required />
                    <span asp-validation-for="LstName" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Age</label>
                    <input asp-for="Age" type="number" class="form-control" required />
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label><b>Gender</b></label>
                    <select asp-for="Gender" class="form-control" required>
                        <option value="">-- Select Gender --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Date of Birth</label>
                    <input asp-for="DOB" type="date" class="form-control" required />
                    <span asp-validation-for="DOB" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Phone</label>
                    <input asp-for="Phone" class="form-control" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>City</label>
                    <input asp-for="City" class="form-control" required />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>


                <div class="col-md-6 mb-3">
                    <label><b>Patient Type</b></label>
                    <select asp-for="PatientType" class="form-control" required>
                        <option value="">-- Select Patient Type --</option>
                        <option value="Inpatient">Inpatient</option>
                        <option value="Outpatient">Outpatient</option>
                        <option value="Emergency">Emergency Patient</option>
                        <option value="LongTermCare">Long-term Care Patient</option>
                    </select>
                    <span asp-validation-for="PatientType" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label><b>Visit Type</b></label>
                    <select asp-for="VisitType" class="form-control" required>
                        <option value="">-- Select Visit Type --</option>
                        <option value="New-Patient">New Patient</option>
                        <option value="Follow-Up">Follow-Up</option>
                    </select>
                    <span asp-validation-for="VisitType" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Disease / Problem</label>
                    <input asp-for="Disease" class="form-control" required />
                    <span asp-validation-for="Disease" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Appointment Date</label>
                    <input asp-for="AppointmentDate" type="date" class="form-control" required />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Select Time Slot</label>
                    <select asp-for="SlotTime" class="form-control" required>
                        <option value="">-- Select Slot --</option>
                        <option>10:00 AM</option>
                        <option>10:30 AM</option>
                        <option>11:00 AM</option>
                        <option>11:30 AM</option>
                        <option>12:00 PM</option>
                        <option>12:30 PM</option>
                        <option>01:00 PM</option>
                        <option>01:30 PM</option>
                        <option>02:00 PM</option>
                        <option>02:30 PM</option>
                        <option>03:00 PM</option>
                        <option>03:30 PM</option>
                        <option>04:00 PM</option>
                        <option>04:30 PM</option>
                        <option>05:00 PM</option>
                    </select>
                    <span asp-validation-for="SlotTime" class="text-danger"></span>
                </div>

                <div class="col-12 mb-3">
                    <label>Message</label>
                    <textarea asp-for="Message" class="form-control"></textarea>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Book Appointment
            </button>
        </form>
    </div>
</div>
<hr />
<h4>Booked Appointments</h4>
<div class="card shadow-sm mb-5">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Appointment ID</th>
                        <th>FName</th>
                        <th>LstName</th>
                        <th>Age</th>
                        <th>Gender</th>
                        <th>DOB</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>PatientType</th>
                        <th>VisitType</th>
                        <th>Disease</th>
                        <th>Date</th>
                        <th>Slot</th>
                        <th>Update</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var CheckUpModel in ViewBag.Appointments)
                    {
                        <tr>
                            <td>@CheckUpModel.AppointmentId</td>
                            <td>@CheckUpModel.FName</td>
                            <td>@CheckUpModel.LstName</td>
                            <td>@CheckUpModel.Age</td>
                            <td>@CheckUpModel.Gender</td>
                            <td>@CheckUpModel.DOB.ToShortDateString()</td>
                            <td>@CheckUpModel.Email</td>
                            <td>@CheckUpModel.Phone</td>
                            <td>@CheckUpModel.City</td>
                            <td>@CheckUpModel.PatientType</td>
                            <td>@CheckUpModel.VisitType</td>
                            <td>@CheckUpModel.Disease</td>
                            <td>@CheckUpModel.AppointmentDate.ToShortDateString()</td>
                            <td>@CheckUpModel.SlotTime</td>
                            <td>
                                <a asp-action="Edit" asp-route-appointmentId="@CheckUpModel.AppointmentId"
                                   class="btn btn-warning btn-sm">Update</a>
                            </td>
                            <td>
                                <a asp-action="Delete"
                                       asp-route-appointmentId="@CheckUpModel.AppointmentId"
                                       class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>