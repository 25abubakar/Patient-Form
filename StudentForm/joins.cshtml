--> GroupBy

Select VisitType from Appointments Group By VisitType;

Select PatientType, Count(*) From Appointments Group By PatientType
having count(*)<5

Select PatientType, Count(*) From Appointments Group By PatientType;
Select PatientType from Appointments Group By PatientType;

Select AppointmentDate, Count(*) From Appointments Group By AppointmentDate;
Select AppointmentDate from Appointments Group By AppointmentDate;

Select SlotTime, Count(*) From Appointments Group By SlotTime;
Select SlotTime from Appointments Group By SlotTime;


--> Joins

Select VisitType From Appointments where PatientType = 'Inpatient'

Select Id,FName,LstName From Patients where Age = '60';

--> Inner Join

SELECT *
FROM Patients p
INNER JOIN Appointments a
ON p.Id = a.PatientID;

--> Natural Join

Select FName, LstName, Disease From Patients, Appointments where Patients.Id = Appointments.PatientId

