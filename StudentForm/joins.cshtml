-- Self Join

Select T1.Phone From Patients as  T1, Patients as T2
where T1.Phone = T2.Phone                                       -- mean disease same ha but message not null ha
And
T1.FName != T2.FName

--> Equi(=) Join

Select LstName From Patients,Appointments where Patients.Id = Appointments.PatientId
And Patients.Id = Appointments.PatientId           -- mean tha in left table address here and other location so than name
--   of the person whose location and address was same
                                                   
--> Left Outer Join

Select Fname,LstName, Disease, VisitType from Patients left outer join Appointments on (Patients.Id = Appointments.PatientId)

--> Right Outer Join

Select Fname,LstName, Disease, VisitType from Patients Right outer join Appointments on (Patients.Id = Appointments.PatientId)

--> Full Outer Join

Select Fname,LstName, Disease, VisitType from Patients Full outer join Appointments on (Patients.Id = Appointments.PatientId) *@
